{
  "swagger": "2.0",
  "info": {
    "title": "Purple Cream API",
    "description": "API for managing Purple Cream products and team members",
    "version": "1.0.0"
  },
  "host": "localhost:3000",
  "basePath": "/api",
  "schemes": [
    "http"
  ],
  "paths": {
    "/products/": {
      "get": {
        "tags": [
          "Products"
        ],
        "description": "Retrieve all products from the database",
        "responses": {
          "200": {
            "description": "OK"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "post": {
        "tags": [
          "Products"
        ],
        "description": "Endpoint to create a new bowl or dish",
        "parameters": [
          {
            "name": "obj",
            "in": "body",
            "description": "Product data",
            "schema": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "example": "Purple Power Bowl"
                },
                "ingredients": {
                  "type": "string",
                  "example": "Acai, Blueberries, Granola, Almond Butter"
                },
                "price": {
                  "type": "number",
                  "example": 15.9
                },
                "image": {
                  "type": "string",
                  "example": "https://images.unsplash.com/photo-1590301157890-4810ed352733"
                },
                "category": {
                  "type": "string",
                  "example": "Premium Bowl"
                },
                "calories": {
                  "type": "number",
                  "example": 520
                },
                "available": {
                  "type": "boolean",
                  "example": true
                },
                "isVegan": {
                  "type": "boolean",
                  "example": true
                }
              },
              "required": [
                "name",
                "ingredients",
                "price",
                "image"
              ]
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/products/{id}": {
      "get": {
        "tags": [
          "Products"
        ],
        "description": "Retrieve a single product by its ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          },
          "404": {
            "description": "Not Found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "put": {
        "tags": [
          "Products"
        ],
        "description": "Update an existing product by its ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "obj",
            "in": "body",
            "description": "Partial or full product data",
            "schema": {
              "type": "object",
              "properties": {
                "price": {
                  "type": "number",
                  "example": 16.5
                },
                "available": {
                  "type": "boolean",
                  "example": false
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not Found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "delete": {
        "tags": [
          "Products"
        ],
        "description": "Delete a product from the database permanently",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not Found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/team/": {
      "get": {
        "tags": [
          "Team"
        ],
        "description": "Retrieve all team members",
        "responses": {
          "200": {
            "description": "OK"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "post": {
        "tags": [
          "Team"
        ],
        "description": "Create a new team member",
        "parameters": [
          {
            "name": "obj",
            "in": "body",
            "description": "Team member data",
            "schema": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "example": "John Doe"
                },
                "title": {
                  "type": "string",
                  "example": "Chief Acai Officer"
                },
                "description": {
                  "type": "string",
                  "example": "Acai enthusiast with 10 years of experience"
                },
                "image": {
                  "type": "string",
                  "example": "https://example.com/john.jpg"
                },
                "role": {
                  "type": "string",
                  "example": "Founder"
                },
                "email": {
                  "type": "string",
                  "example": "john@purplecream.com"
                },
                "hobbies": {
                  "type": "array",
                  "example": [
                    "Surfing",
                    "Healthy Living"
                  ],
                  "items": {
                    "type": "string"
                  }
                }
              },
              "required": [
                "name",
                "title",
                "description",
                "image",
                "email"
              ]
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/team/{id}": {
      "get": {
        "tags": [
          "Team"
        ],
        "description": "Retrieve a team member by ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          },
          "404": {
            "description": "Not Found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "put": {
        "tags": [
          "Team"
        ],
        "description": "Update a team member by ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "obj",
            "in": "body",
            "description": "Team member data to update",
            "schema": {
              "type": "object",
              "properties": {
                "title": {
                  "type": "string",
                  "example": "CEO"
                },
                "role": {
                  "type": "string",
                  "example": "Management"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not Found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "delete": {
        "tags": [
          "Team"
        ],
        "description": "Remove a team member from the database",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not Found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    }
  }
}